    "task",
    "shell"
  ],
  "dependencies": {
    "adm-zip": "^0.5.16",
    "anyproxy": "^4.1.3",
    "axios": "^1.12.2",
    "cheerio": "^1.1.2",
    "formidable": "^2.0.1",
    "node-cron": "^4.2.1",
    "pm2": "^6.0.13",
    "rss": "^1.2.2"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^7.0.0",
    "css-loader": "^6.7.1",
    "css-minimizer-webpack-plugin": "^4.1.0",
    "html-webpack-plugin": "^5.5.0",
    "mini-css-extract-plugin": "^2.6.1",
    "terser-webpack-plugin": "^5.3.0",
    "vue": "^2.7.10",
    "vue-draggable-resizable": "^2.3.0",
    "vue-loader": "^15.10.0",
    "webpack": "^5.101.3",
